---
import homeData from "../../content/home.json";
const home = homeData;
const phoneTel = "tel:" + home.business.phoneHref;
const mailTo = "mailto:" + home.business.email;

const { title, description, canonical, schema, ogImage } = Astro.props;
const img = ogImage || "https://offerfabrications.com.au/assets/img/hero-ute-generator.jpg";
---
<!DOCTYPE html>
<html lang="en-AU">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={img} />
<meta property="og:type" content="website" />
<meta property="og:url" content={canonical} />
<meta property="og:site_name" content="Offer Fabrications" />
<meta property="og:locale" content="en_AU" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={img} />
<meta name="geo.region" content="AU-WA" />
<meta name="author" content="Offer Fabrications" />
<link rel="icon" type="image/png" href="/assets/logo/offer-logo.png" />
{schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
<script is:inline src="https://cdn.tailwindcss.com"></script>
<script is:inline>
  tailwind.config = {
    theme: { extend: { fontFamily: {
      display: ['"Space Grotesk"', 'system-ui', 'sans-serif'],
      body: ['Inter', 'system-ui', 'sans-serif'],
    } } },
  };
</script>
<style is:global>
  :root {
    --paper:#ffffff; --paper-2:#f5f4f1; --paper-3:#eae7e1;
    --ink:#17191e; --ink-2:#33363d; --muted:#6b7079; --line:#e4e2dd;
    --accent:#e0531e; --navy:#1c3f8f;
  }
  * { -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility; }
  html { scroll-behavior: smooth; }
  body { background: var(--paper); color: var(--ink); font-family: 'Inter', sans-serif; overflow-x: hidden; }
  .font-display { font-family: 'Space Grotesk', sans-serif; }
  h1, h2, h3, h4 { font-family: 'Space Grotesk', sans-serif; letter-spacing: -0.02em; }
  .ink { color: var(--ink); } .muted { color: var(--muted); } .accent { color: var(--accent); }
  .bg-paper-2 { background: var(--paper-2); } .bg-ink { background: var(--ink); } .line { border-color: var(--line); }
  .kicker { font-family:'Inter',sans-serif; text-transform:uppercase; letter-spacing:.2em; font-weight:600; font-size:.72rem; color:var(--accent); display:inline-flex; align-items:center; gap:.6rem; }
  .kicker::before { content:""; width:26px; height:1px; background:var(--accent); display:inline-block; }
  .kicker.on-dark { color:#fff; } .kicker.on-dark::before { background:var(--accent); }
  .h-hero { font-size: clamp(2.4rem, 7vw, 4.6rem); line-height: 1.0; font-weight: 700; }
  .h-sec { font-size: clamp(2rem, 5.2vw, 3.6rem); line-height: 1.0; font-weight: 700; }
  .h-feat { font-size: clamp(1.75rem, 4vw, 2.9rem); line-height: 1.03; font-weight: 700; }
  .lead { font-size: clamp(1.02rem, 1.5vw, 1.2rem); line-height: 1.7; color: var(--muted); }
  .btn { display:inline-flex; align-items:center; justify-content:center; gap:.6rem; font-family:'Space Grotesk',sans-serif; font-weight:500; letter-spacing:.02em; padding:1rem 1.75rem; border-radius:2px; transition: all .2s ease; font-size:.95rem; }
  .btn-primary { background: var(--ink); color:#fff; } .btn-primary:hover { background: var(--accent); transform: translateY(-1px); }
  .btn-ghost { background: transparent; color: var(--ink); border:1px solid var(--line); } .btn-ghost:hover { border-color: var(--ink); }
  .btn-light { background:#fff; color:var(--ink); } .btn-light:hover { background: var(--accent); color:#fff; }
  .btn-outline-light { background: transparent; color:#fff; border:1px solid rgba(255,255,255,.35); } .btn-outline-light:hover { border-color:#fff; background: rgba(255,255,255,.08); }
  .link-arrow { display:inline-flex; align-items:center; gap:.45rem; font-family:'Space Grotesk',sans-serif; font-weight:500; color:var(--ink); font-size:.95rem; }
  .link-arrow svg { transition: transform .2s ease; } .link-arrow:hover svg { transform: translateX(4px); }
  .card { background:#fff; border:1px solid var(--line); border-radius:3px; transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease; }
  .card:hover { transform: translateY(-4px); box-shadow: 0 18px 40px -24px rgba(0,0,0,.35); border-color:#d5d2cc; }
  .imgcover { width:100%; height:100%; object-fit:cover; display:block; }
  .nav { transition: background .3s ease, box-shadow .3s ease, border-color .3s ease; }
  .nav-solid { background: rgba(255,255,255,.92); backdrop-filter: blur(12px); border-bottom:1px solid var(--line); }
  .nav-link { position:relative; font-family:'Space Grotesk',sans-serif; font-weight:500; font-size:.94rem; color:var(--ink-2); }
  .nav-link::after { content:""; position:absolute; left:0; bottom:-5px; height:2px; width:0; background:var(--accent); transition:width .25s ease; }
  .nav-link:hover::after { width:100%; } .nav-link:hover { color:var(--ink); }
  .ico { width:2.1rem; height:2.1rem; stroke: var(--accent); fill:none; stroke-width:1.4; stroke-linecap:round; stroke-linejoin:round; }
  .ico-sm { width:1.35rem; height:1.35rem; stroke: currentColor; fill:none; stroke-width:1.6; stroke-linecap:round; stroke-linejoin:round; }
  ::selection { background: var(--accent); color:#fff; }
  a { text-decoration:none; }
  #mobileMenu { transition: opacity .3s ease, visibility .3s ease; }
  #mobileMenu.hidden-menu { opacity:0; visibility:hidden; pointer-events:none; }
  #mobileBar { box-shadow: 0 -10px 30px -12px rgba(0,0,0,.25); }
  @media (min-width:1024px){ #mobileBar { display:none; } }
  @media (max-width:1023px){ body { padding-bottom: 4.25rem; } }
  a:focus-visible, button:focus-visible, input:focus-visible, select:focus-visible, textarea:focus-visible { outline:2px solid var(--accent); outline-offset:2px; }
</style>
</head>
<body>

<!-- TOP BAR -->
<div class="hidden md:block bg-ink text-white/80">
  <div class="max-w-[1280px] mx-auto px-6 h-9 flex items-center justify-between text-[12.5px] font-medium tracking-wide">
    <div class="flex items-center gap-6">
      <span>{home.business.address}</span>
      <span class="text-white/30">|</span>
      <span>{home.business.hours}</span>
    </div>
    <div class="flex items-center gap-6">
      <a href={home.business.instagramUrl} target="_blank" rel="noopener" class="hover:text-white transition">{home.business.instagram}</a>
    </div>
  </div>
</div>

<!-- NAV -->
<header id="nav" class="nav nav-solid sticky top-0 z-40">
  <div class="max-w-[1280px] mx-auto px-6 h-[68px] flex items-center justify-between">
    <a href="/" class="flex items-center">
      <img src="/assets/logo/offer-logo-header.png" alt="Offer Fabrications" class="h-14 w-auto" />
    </a>
    <nav class="hidden lg:flex items-center gap-9">
      <a href="/#services" class="nav-link">Capabilities</a>
      <a href="/#work" class="nav-link">Our Work</a>
      <a href="/#industries" class="nav-link">Industries</a>
      <a href="/locations/" class="nav-link">Areas We Serve</a>
      <a href="/#contact" class="nav-link">Contact</a>
    </nav>
    <div class="flex items-center gap-3">
      <a href={phoneTel} class="hidden sm:inline-flex link-arrow text-sm mr-1">{home.business.phone}</a>
      <a href="/#contact" class="hidden sm:inline-flex btn btn-primary !py-2.5 !px-5 text-sm">Get a Quote</a>
      <button id="menuBtn" aria-label="Open menu" class="lg:hidden w-10 h-10 grid place-items-center">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
      </button>
    </div>
  </div>
</header>

<!-- mobile menu -->
<div id="mobileMenu" class="hidden-menu fixed inset-0 z-50 bg-white lg:hidden flex flex-col">
  <div class="h-[68px] px-6 flex items-center justify-between border-b line">
    <img src="/assets/logo/offer-logo-header.png" alt="Offer Fabrications" class="h-11 w-auto" />
    <button id="menuClose" aria-label="Close menu" class="w-10 h-10 grid place-items-center">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
    </button>
  </div>
  <nav class="flex-1 px-6 py-4 flex flex-col">
    <a href="/#services" class="menu-item font-display text-[1.7rem] font-medium py-4 border-b line flex items-center justify-between">Capabilities <span class="accent text-base">→</span></a>
    <a href="/#work" class="menu-item font-display text-[1.7rem] font-medium py-4 border-b line flex items-center justify-between">Our Work <span class="accent text-base">→</span></a>
    <a href="/#industries" class="menu-item font-display text-[1.7rem] font-medium py-4 border-b line flex items-center justify-between">Industries <span class="accent text-base">→</span></a>
    <a href="/locations/" class="menu-item font-display text-[1.7rem] font-medium py-4 border-b line flex items-center justify-between">Areas We Serve <span class="accent text-base">→</span></a>
    <a href="/#contact" class="menu-item font-display text-[1.7rem] font-medium py-4 border-b line flex items-center justify-between">Contact <span class="accent text-base">→</span></a>
  </nav>
  <div class="px-6 py-6 border-t line space-y-3">
    <a href={phoneTel} class="btn btn-primary w-full">Call {home.business.phone}</a>
    <a href="/#contact" class="menu-item btn btn-ghost w-full">Request a Quote</a>
  </div>
</div>

<slot />

<!-- FOOTER -->
<footer class="bg-ink text-white">
  <div class="max-w-[1280px] mx-auto px-6 py-16 grid md:grid-cols-3 gap-10">
    <div>
      <div class="mb-5">
        <img src="/assets/logo/offer-logo-full.png" alt="Offer Fabrications" class="h-20 w-auto" />
      </div>
      <p class="text-white/55 text-sm max-w-xs leading-relaxed">{home.footer.blurb}</p>
    </div>
    <div>
      <h4 class="text-[11px] uppercase tracking-widest text-white/40 mb-4 font-semibold">Explore</h4>
      <ul class="space-y-2.5 text-white/70 text-sm">
        <li><a href="/#services" class="hover:text-white transition">Capabilities</a></li>
        <li><a href="/#work" class="hover:text-white transition">Our Work</a></li>
        <li><a href="/#industries" class="hover:text-white transition">Industries</a></li>
        <li><a href="/locations/" class="hover:text-white transition">Areas We Serve</a></li>
        <li><a href="/#faq" class="hover:text-white transition">FAQ</a></li>
        <li><a href="/#contact" class="hover:text-white transition">Get a Quote</a></li>
      </ul>
    </div>
    <div>
      <h4 class="text-[11px] uppercase tracking-widest text-white/40 mb-4 font-semibold">Contact</h4>
      <ul class="space-y-2.5 text-white/70 text-sm">
        <li><a href={phoneTel} class="hover:text-white transition">{home.business.phone}</a></li>
        <li><a href={mailTo} class="hover:text-white transition">{home.business.email}</a></li>
        <li>{home.business.address}</li>
        <li><a href={home.business.instagramUrl} target="_blank" rel="noopener" class="hover:text-white transition">{home.business.instagram}</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-white/10">
    <div class="max-w-[1280px] mx-auto px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-white/45">
      <span>© <span id="yr"></span> Offer Fabrications. All rights reserved.</span>
      <span>Website by <a href="https://intrlude.com.au" target="_blank" rel="noopener" class="text-white/70 hover:text-[var(--accent)] transition">Intrlude</a></span>
    </div>
  </div>
</footer>

<!-- STICKY MOBILE BAR -->
<div id="mobileBar" class="fixed bottom-0 inset-x-0 z-30 bg-white border-t line grid grid-cols-2 gap-2 p-2.5 lg:hidden">
  <a href={phoneTel} class="btn btn-ghost !py-3 text-sm">Call</a>
  <a href="/#contact" class="btn btn-primary !py-3 text-sm">Get a Quote</a>
</div>

<script is:inline>
  document.getElementById('yr').textContent = new Date().getFullYear();
  const menu = document.getElementById('mobileMenu');
  const closeM = () => { menu.classList.add('hidden-menu'); document.body.style.overflow=''; };
  document.getElementById('menuBtn').addEventListener('click', () => { menu.classList.remove('hidden-menu'); document.body.style.overflow='hidden'; });
  document.getElementById('menuClose').addEventListener('click', closeM);
  menu.querySelectorAll('.menu-item').forEach(a => a.addEventListener('click', closeM));
</script>
</body>
</html>
