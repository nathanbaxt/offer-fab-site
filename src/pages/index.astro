---
import homeData from "../../content/home.json";
const home = homeData;

const capIcons = [
  '<path d="M4 5h16M4 19h16M12 5v14"/><path d="M8 5v2M16 5v2M8 17v2M16 17v2"/>',
  '<path d="M12 3l1.8 5.4L19 10l-5.2 1.6L12 17l-1.8-5.4L5 10l5.2-1.6z"/><path d="M18.5 15.5l.7 2 2 .7-2 .7-.7 2-.7-2-2-.7 2-.7z"/>',
  '<path d="M12 3l9 5-9 5-9-5 9-5z"/><path d="M3 13l9 5 9-5"/>',
  '<rect x="3" y="4" width="18" height="16" rx="1"/><path d="M3 10h18M9 4v16"/>',
  '<circle cx="12" cy="12" r="2.3"/><path d="M12 3v3.5M12 17.5V21M3 12h3.5M17.5 12H21M5.6 5.6l2.5 2.5M15.9 15.9l2.5 2.5M18.4 5.6l-2.5 2.5M8.1 15.9l-2.5 2.5"/>',
  '<path d="M3 7h18M3 18h18M6 7v11M10 7v11M14 7v11M18 7v11"/>',
];
const indIcons = [
  '<path d="M3 19h18L14.5 8l-3.5 5.5L9 11l-6 8z"/><circle cx="17.5" cy="6" r="1.6"/>',
  '<path d="M12 21a5 5 0 0 0 5-5c0-4-3.5-5-2.5-9.5C11 8 8 11 8 16a4 4 0 0 0 4 5z"/>',
  '<path d="M3 18a9 9 0 0 1 18 0"/><path d="M9 9V6h6v3"/><path d="M2.5 18h19"/>',
  '<path d="M4 16h16l-2.4 4H6.4L4 16z"/><path d="M12 3v11M12 5l5 7H12"/>',
  '<rect x="5" y="3" width="14" height="18"/><path d="M9 7h2M13 7h2M9 11h2M13 11h2M9 15h2M13 15h2"/>',
  '<path d="M3 9c4 3.5 14 3.5 18 0"/><path d="M3 9v8M21 9v8M3 17h18M9 12v5M15 12v5M12 11v6"/>',
];
const phoneTel = "tel:" + home.business.phoneHref;
const mailTo = "mailto:" + home.business.email;
---
<!DOCTYPE html>
<html lang="en-AU">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Offer Fabrications | Custom Steel, Stainless & Aluminium Fabrication — Bibra Lake, Perth WA</title>
<meta name="description" content="Offer Fabrications is a Bibra Lake metal fabrication workshop delivering custom steel, stainless and aluminium fabrication for mining, industrial, commercial and trade clients across WA. Workshop-built and site-installed." />
<meta property="og:title" content="Offer Fabrications — Custom Metal Fabrication, Perth WA" />
<meta property="og:description" content="Custom steel, stainless and aluminium fabrication for mining, industrial, commercial and trade — built in Bibra Lake, installed across WA." />
<meta property="og:image" content="/assets/img/hero-ute-generator.jpg" />
<meta property="og:type" content="website" />
<link rel="icon" type="image/png" href="/assets/logo/offer-logo.png" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
<script is:inline src="https://cdn.tailwindcss.com"></script>
<script is:inline>
  tailwind.config = {
    theme: { extend: { fontFamily: {
      display: ['"Space Grotesk"', 'system-ui', 'sans-serif'],
      body: ['Inter', 'system-ui', 'sans-serif'],
    } } },
  };
</script>
<style is:global>
  :root {
    --paper:#ffffff; --paper-2:#f5f4f1; --paper-3:#eae7e1;
    --ink:#17191e; --ink-2:#33363d; --muted:#6b7079; --line:#e4e2dd;
    --accent:#e0531e; --navy:#1c3f8f;
  }
  * { -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility; }
  html { scroll-behavior: smooth; }
  body { background: var(--paper); color: var(--ink); font-family: 'Inter', sans-serif; overflow-x: hidden; }
  .font-display { font-family: 'Space Grotesk', sans-serif; }
  h1, h2, h3, h4 { font-family: 'Space Grotesk', sans-serif; letter-spacing: -0.02em; }
  .ink { color: var(--ink); } .muted { color: var(--muted); } .accent { color: var(--accent); }
  .bg-paper-2 { background: var(--paper-2); } .bg-ink { background: var(--ink); } .line { border-color: var(--line); }
  .kicker { font-family:'Inter',sans-serif; text-transform:uppercase; letter-spacing:.2em; font-weight:600; font-size:.72rem; color:var(--accent); display:inline-flex; align-items:center; gap:.6rem; }
  .kicker::before { content:""; width:26px; height:1px; background:var(--accent); display:inline-block; }
  .kicker.on-dark { color:#fff; } .kicker.on-dark::before { background:var(--accent); }
  .h-hero { font-size: clamp(2.6rem, 8.5vw, 6rem); line-height: .96; font-weight: 700; }
  .h-sec { font-size: clamp(2rem, 5.2vw, 3.6rem); line-height: 1.0; font-weight: 700; }
  .h-feat { font-size: clamp(1.75rem, 4vw, 2.9rem); line-height: 1.03; font-weight: 700; }
  .lead { font-size: clamp(1.02rem, 1.5vw, 1.2rem); line-height: 1.7; color: var(--muted); }
  .btn { display:inline-flex; align-items:center; justify-content:center; gap:.6rem; font-family:'Space Grotesk',sans-serif; font-weight:500; letter-spacing:.02em; padding:1rem 1.75rem; border-radius:2px; transition: all .2s ease; font-size:.95rem; }
  .btn-primary { background: var(--ink); color:#fff; } .btn-primary:hover { background: var(--accent); transform: translateY(-1px); }
  .btn-ghost { background: transparent; color: var(--ink); border:1px solid var(--line); } .btn-ghost:hover { border-color: var(--ink); }
  .btn-light { background:#fff; color:var(--ink); } .btn-light:hover { background: var(--accent); color:#fff; }
  .btn-outline-light { background: transparent; color:#fff; border:1px solid rgba(255,255,255,.35); } .btn-outline-light:hover { border-color:#fff; background: rgba(255,255,255,.08); }
  .link-arrow { display:inline-flex; align-items:center; gap:.45rem; font-family:'Space Grotesk',sans-serif; font-weight:500; color:var(--ink); font-size:.95rem; }
  .link-arrow svg { transition: transform .2s ease; } .link-arrow:hover svg { transform: translateX(4px); }
  .card { background:#fff; border:1px solid var(--line); border-radius:3px; transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease; }
  .card:hover { transform: translateY(-4px); box-shadow: 0 18px 40px -24px rgba(0,0,0,.35); border-color:#d5d2cc; }
  .imgcover { width:100%; height:100%; object-fit:cover; display:block; }
  /* hero: mobile crop (default centre) is fine per client; on desktop the frame is
     shorter/wider, so push the crop down to keep the ute + OFFER FABRICATIONS signage in view */
  @media (min-width:1024px){ .hero-img { object-position: center 72%; } }
  .zoom { overflow:hidden; } .zoom img { transition: transform .7s cubic-bezier(.2,.7,.2,1); } .zoom:hover img { transform: scale(1.06); }
  .ring-frame { position:relative; } .ring-frame::after { content:""; position:absolute; left:16px; top:16px; right:-16px; bottom:-16px; border:1px solid var(--line); border-radius:3px; z-index:-1; }
  .nav { transition: background .3s ease, box-shadow .3s ease, border-color .3s ease; }
  .nav-solid { background: rgba(255,255,255,.92); backdrop-filter: blur(12px); border-bottom:1px solid var(--line); }
  .nav-link { position:relative; font-family:'Space Grotesk',sans-serif; font-weight:500; font-size:.94rem; color:var(--ink-2); }
  .nav-link::after { content:""; position:absolute; left:0; bottom:-5px; height:2px; width:0; background:var(--accent); transition:width .25s ease; }
  .nav-link:hover::after { width:100%; } .nav-link:hover { color:var(--ink); }
  .ico { width:2.1rem; height:2.1rem; stroke: var(--accent); fill:none; stroke-width:1.4; stroke-linecap:round; stroke-linejoin:round; }
  .ico-sm { width:1.35rem; height:1.35rem; stroke: currentColor; fill:none; stroke-width:1.6; stroke-linecap:round; stroke-linejoin:round; }
  .reveal { opacity:0; transform: translateY(26px); transition: opacity .8s cubic-bezier(.2,.7,.2,1), transform .8s cubic-bezier(.2,.7,.2,1); }
  .reveal.in { opacity:1; transform:none; }
  /* company marquee */
  .marquee { overflow:hidden; white-space:nowrap; -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent); mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent); }
  .marquee-track { display:inline-block; animation: mscroll 34s linear infinite; }
  @keyframes mscroll { from { transform: translateX(0);} to { transform: translateX(-50%);} }
  .diamond { color: var(--accent); margin: 0 1.9rem; font-size:.55em; vertical-align:middle; }
  ::selection { background: var(--accent); color:#fff; }
  a { text-decoration:none; }
  section[id] { scroll-margin-top: 76px; }
  #mobileMenu { transition: opacity .3s ease, visibility .3s ease; }
  #mobileMenu.hidden-menu { opacity:0; visibility:hidden; pointer-events:none; }
  #mobileBar { box-shadow: 0 -10px 30px -12px rgba(0,0,0,.25); }
  @media (min-width:1024px){ #mobileBar { display:none; } }
  @media (max-width:1023px){ body { padding-bottom: 4.25rem; } }
  a:focus-visible, button:focus-visible, input:focus-visible, select:focus-visible, textarea:focus-visible { outline:2px solid var(--accent); outline-offset:2px; }
</style>
</head>
<body>

<!-- TOP BAR -->
<div class="hidden md:block bg-ink text-white/80">
  <div class="max-w-[1280px] mx-auto px-6 h-9 flex items-center justify-between text-[12.5px] font-medium tracking-wide">
    <div class="flex items-center gap-6">
      <span>{home.business.address}</span>
      <span class="text-white/30">|</span>
      <span>{home.business.hours}</span>
    </div>
    <div class="flex items-center gap-6">
      <a href={home.business.instagramUrl} target="_blank" rel="noopener" class="hover:text-white transition">{home.business.instagram}</a>
    </div>
  </div>
</div>

<!-- NAV -->
<header id="nav" class="nav nav-solid sticky top-0 z-40">
  <div class="max-w-[1280px] mx-auto px-6 h-[68px] flex items-center justify-between">
    <a href="#top" class="flex items-center">
      <img src="/assets/logo/offer-logo-header.png" alt="Offer Fabrications" class="h-14 w-auto" />
    </a>
    <nav class="hidden lg:flex items-center gap-9">
      <a href="#services" class="nav-link">Capabilities</a>
      <a href="#work" class="nav-link">Our Work</a>
      <a href="#industries" class="nav-link">Industries</a>
      <a href="#about" class="nav-link">About</a>
      <a href="#contact" class="nav-link">Contact</a>
    </nav>
    <div class="flex items-center gap-3">
      <a href={phoneTel} class="hidden sm:inline-flex link-arrow text-sm mr-1">{home.business.phone}</a>
      <a href="#contact" class="hidden sm:inline-flex btn btn-primary !py-2.5 !px-5 text-sm">Get a Quote</a>
      <button id="menuBtn" aria-label="Open menu" class="lg:hidden w-10 h-10 grid place-items-center">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
      </button>
    </div>
  </div>
</header>

<!-- mobile menu -->
<div id="mobileMenu" class="hidden-menu fixed inset-0 z-50 bg-white lg:hidden flex flex-col">
  <div class="h-[68px] px-6 flex items-center justify-between border-b line">
    <img src="/assets/logo/offer-logo-header.png" alt="Offer Fabrications" class="h-11 w-auto" />
    <button id="menuClose" aria-label="Close menu" class="w-10 h-10 grid place-items-center">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
    </button>
  </div>
  <nav class="flex-1 px-6 py-4 flex flex-col">
    <a href="#services" class="menu-item font-display text-[1.7rem] font-medium py-4 border-b line flex items-center justify-between">Capabilities <span class="accent text-base">→</span></a>
    <a href="#work" class="menu-item font-display text-[1.7rem] font-medium py-4 border-b line flex items-center justify-between">Our Work <span class="accent text-base">→</span></a>
    <a href="#industries" class="menu-item font-display text-[1.7rem] font-medium py-4 border-b line flex items-center justify-between">Industries <span class="accent text-base">→</span></a>
    <a href="#about" class="menu-item font-display text-[1.7rem] font-medium py-4 border-b line flex items-center justify-between">About <span class="accent text-base">→</span></a>
    <a href="#contact" class="menu-item font-display text-[1.7rem] font-medium py-4 border-b line flex items-center justify-between">Contact <span class="accent text-base">→</span></a>
  </nav>
  <div class="px-6 py-6 border-t line space-y-3">
    <a href={phoneTel} class="btn btn-primary w-full">Call {home.business.phone}</a>
    <a href="#contact" class="menu-item btn btn-ghost w-full">Request a Quote</a>
  </div>
</div>

<!-- HERO -->
<section id="top" class="relative">
  <div class="relative min-h-[86vh] lg:min-h-[88vh] flex items-end">
    <img src={home.hero.image} alt="Offer Fabrications branded HiLux beside a custom-built generator enclosure" class="absolute inset-0 imgcover hero-img" />
    <div class="absolute inset-0" style="background:linear-gradient(180deg, rgba(15,16,20,.45) 0%, rgba(15,16,20,.15) 38%, rgba(15,16,20,.55) 78%, rgba(15,16,20,.86) 100%)"></div>
    <div class="relative z-10 w-full max-w-[1280px] mx-auto px-6 pb-16 lg:pb-24 text-white">
      <div class="max-w-3xl">
        <div class="kicker on-dark mb-6">{home.hero.kicker}</div>
        <h1 class="h-hero font-display">{home.hero.titleLine1}<br/>{home.hero.titleLine2}<br/>{home.hero.titleLine3}</h1>
        <p class="lead !text-white/80 mt-6 max-w-xl">{home.hero.sub}</p>
        <div class="mt-9 flex flex-wrap gap-3">
          <a href="#contact" class="btn btn-light">{home.hero.ctaPrimary}</a>
          <a href="#work" class="btn btn-outline-light">{home.hero.ctaSecondary}</a>
        </div>
      </div>
    </div>
  </div>
  <div class="bg-ink text-white py-6 overflow-hidden">
    <p class="text-center text-[10px] tracking-[0.3em] uppercase text-white/40 mb-4">Fabrication trusted on major WA sites</p>
    <div class="marquee">
      <div class="marquee-track">
        {[...home.projects.companies, ...home.projects.companies].map((c) => (
          <span class="inline-flex items-center align-middle">
            <img src={c.logo} alt={c.name} class="h-7 sm:h-9 w-auto object-contain opacity-70 hover:opacity-100 transition" />
            <span class="diamond">◆</span>
          </span>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- INTRO -->
<section class="max-w-[1280px] mx-auto px-6 py-20 lg:py-28">
  <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-start">
    <div class="lg:col-span-7 reveal">
      <div class="kicker mb-5">{home.intro.kicker}</div>
      <h2 class="h-sec font-display">{home.intro.heading}</h2>
    </div>
    <div class="lg:col-span-5 reveal">
      <p class="lead">{home.intro.body}</p>
      <a href="#about" class="link-arrow mt-6">More about us <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
    </div>
  </div>
</section>

<!-- CAPABILITIES -->
<section id="services" class="bg-paper-2 border-y line">
  <div class="max-w-[1280px] mx-auto px-6 py-20 lg:py-28">
    <div class="reveal flex flex-col md:flex-row md:items-end justify-between gap-5 mb-14">
      <div>
        <div class="kicker mb-4">{home.capabilities.kicker}</div>
        <h2 class="h-sec font-display">{home.capabilities.heading}</h2>
      </div>
      <p class="lead md:max-w-sm md:text-right">{home.capabilities.sub}</p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {home.capabilities.items.map((c, i) => (
        <div class="card p-8 reveal">
          <svg class="ico mb-6" viewBox="0 0 24 24" set:html={capIcons[i % capIcons.length]}></svg>
          <h3 class="font-display font-bold text-xl mb-2">{c.title}</h3>
          <p class="muted text-[.95rem] leading-relaxed">{c.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- FEATURE 1 -->
<section id="about" class="max-w-[1280px] mx-auto px-6 py-20 lg:py-28">
  <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
    <div class="reveal ring-frame zoom rounded-[3px]">
      <img src={home.feature1.image} alt="Fabrication by Offer Fabrications" class="w-full aspect-[4/5] sm:aspect-[4/3] lg:aspect-[4/5] object-cover rounded-[3px]" />
    </div>
    <div class="reveal">
      <div class="kicker mb-5">{home.feature1.kicker}</div>
      <h2 class="h-feat font-display mb-6">{home.feature1.heading}</h2>
      <p class="lead mb-8">{home.feature1.body}</p>
      <ul class="space-y-5">
        {home.feature1.points.map((p, i) => (
          <li class="flex gap-4"><span class="accent font-display font-bold">{String(i + 1).padStart(2, '0')}</span><span class="text-[.98rem]"><span class="font-semibold">{p.strong}</span> <span class="muted">{p.rest}</span></span></li>
        ))}
      </ul>
    </div>
  </div>
</section>

<!-- WORK -->
<section id="work" class="bg-paper-2 border-y line">
  <div class="max-w-[1280px] mx-auto px-6 py-20 lg:py-28">
    <div class="reveal flex flex-col md:flex-row md:items-end justify-between gap-5 mb-12">
      <div>
        <div class="kicker mb-4">{home.work.kicker}</div>
        <h2 class="h-sec font-display">{home.work.heading}</h2>
      </div>
      <p class="lead md:max-w-sm md:text-right">{home.work.sub}</p>
    </div>
    <div class="grid sm:grid-cols-2 gap-4 sm:gap-5">
      {home.work.items.map((w) => (
        <figure class="zoom relative rounded-[3px] overflow-hidden reveal">
          <img src={w.image} alt={w.caption || "Fabrication by Offer Fabrications"} class="w-full aspect-[4/3] object-cover" />
          {w.caption && (
            <figcaption class="absolute inset-x-0 bottom-0 p-5 bg-gradient-to-t from-black/75 to-transparent text-white">
              {w.tag && <span class="text-[11px] tracking-widest uppercase text-white/70 font-medium">{w.tag}</span>}
              <div class="font-display font-semibold text-lg">{w.caption}</div>
            </figcaption>
          )}
        </figure>
      ))}
    </div>
  </div>
</section>

<!-- STATS -->
<section class="max-w-[1280px] mx-auto px-6 py-16 lg:py-20">
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-y-10 divide-y-0 lg:divide-x line reveal">
    {home.stats.map((s) => (
      <div class="lg:px-8 first:pl-0"><div class="font-display font-bold text-5xl lg:text-6xl" set:html={s.value.replace('%', '<span class=\'accent\'>%</span>')}></div><div class="muted text-sm mt-2">{s.label}</div></div>
    ))}
  </div>
</section>

<!-- INDUSTRIES -->
<section id="industries" class="max-w-[1280px] mx-auto px-6 py-20 lg:py-28">
  <div class="reveal mb-12">
    <div class="kicker mb-4">{home.industries.kicker}</div>
    <h2 class="h-sec font-display">{home.industries.heading}</h2>
  </div>
  <div class="grid grid-cols-2 lg:grid-cols-3 gap-4 reveal">
    {home.industries.items.map((ind, i) => (
      <div class="card p-7 flex items-center gap-4"><span class="accent"><svg class="ico-sm" viewBox="0 0 24 24" style="stroke:var(--accent)" set:html={indIcons[i % indIcons.length]}></svg></span><span class="font-display font-semibold text-[1.05rem]">{ind.name}</span></div>
    ))}
  </div>
</section>

<!-- PROCESS -->
<section class="bg-paper-2 border-y line">
  <div class="max-w-[1280px] mx-auto px-6 py-20 lg:py-28">
    <div class="reveal mb-14">
      <div class="kicker mb-4">{home.process.kicker}</div>
      <h2 class="h-sec font-display">{home.process.heading}</h2>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-10">
      {home.process.steps.map((st, i) => (
        <div class="reveal"><div class="font-display font-bold text-5xl accent">{String(i + 1).padStart(2, '0')}</div><div class="h-px w-full my-5" style="background:var(--line)"></div><h3 class="font-display font-bold text-xl mb-2">{st.title}</h3><p class="muted text-[.95rem]">{st.body}</p></div>
      ))}
    </div>
  </div>
</section>

<!-- CONTACT -->
<section id="contact" class="max-w-[1280px] mx-auto px-6 py-20 lg:py-28">
  <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
    <div class="reveal">
      <div class="kicker mb-4">{home.contact.kicker}</div>
      <h2 class="h-sec font-display mb-6">{home.contact.heading}</h2>
      <p class="lead mb-10 max-w-md">{home.contact.sub}</p>
      <div class="space-y-2">
        <a href={phoneTel} class="flex items-center gap-4 py-4 border-t line group">
          <span class="w-11 h-11 bg-paper-2 border line rounded-[3px] grid place-items-center accent shrink-0"><svg class="ico-sm" viewBox="0 0 24 24" style="stroke:var(--accent)"><path d="M5 4h3.4l1.7 4.3-2.1 1.3a11 11 0 0 0 5 5l1.3-2.1L18.7 16v3.2a2 2 0 0 1-2 2A14.5 14.5 0 0 1 2.8 7a2 2 0 0 1 2.2-3z"/></svg></span>
          <span><span class="block text-[11px] muted uppercase tracking-widest">Call</span><span class="text-lg font-display font-semibold group-hover:accent transition">{home.business.phone}</span></span>
        </a>
        <a href={mailTo} class="flex items-center gap-4 py-4 border-t line group">
          <span class="w-11 h-11 bg-paper-2 border line rounded-[3px] grid place-items-center accent shrink-0"><svg class="ico-sm" viewBox="0 0 24 24" style="stroke:var(--accent)"><rect x="3" y="5" width="18" height="14" rx="1"/><path d="M3.5 6.5L12 13l8.5-6.5"/></svg></span>
          <span><span class="block text-[11px] muted uppercase tracking-widest">Email</span><span class="text-lg font-display font-semibold group-hover:accent transition break-all">{home.business.email}</span></span>
        </a>
        <div class="flex items-center gap-4 py-4 border-t line">
          <span class="w-11 h-11 bg-paper-2 border line rounded-[3px] grid place-items-center accent shrink-0"><svg class="ico-sm" viewBox="0 0 24 24" style="stroke:var(--accent)"><path d="M12 21s7-5.6 7-11a7 7 0 0 0-14 0c0 5.4 7 11 7 11z"/><circle cx="12" cy="10" r="2.4"/></svg></span>
          <span><span class="block text-[11px] muted uppercase tracking-widest">Workshop</span><span class="text-lg font-display font-semibold">{home.business.address}</span></span>
        </div>
        <a href={home.business.instagramUrl} target="_blank" rel="noopener" class="flex items-center gap-4 py-4 border-t border-b line group">
          <span class="w-11 h-11 bg-paper-2 border line rounded-[3px] grid place-items-center accent shrink-0"><svg class="ico-sm" viewBox="0 0 24 24" style="stroke:var(--accent)"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17" cy="6.8" r="1"/></svg></span>
          <span><span class="block text-[11px] muted uppercase tracking-widest">Instagram</span><span class="text-lg font-display font-semibold group-hover:accent transition">{home.business.instagram}</span></span>
        </a>
      </div>
      <div class="mt-8 rounded-[3px] overflow-hidden border line">
        <iframe title="Offer Fabrications location" width="100%" height="230" style="border:0;filter:grayscale(.4) contrast(.95)" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
          src="https://www.google.com/maps?q=Salpietro+Street+Bibra+Lake+WA+6163&output=embed"></iframe>
      </div>
    </div>
    <div class="reveal">
      <div class="bg-paper-2 border line rounded-[3px] p-7 sm:p-9">
        <form name="quote" method="POST" action="/success/" data-netlify="true" netlify-honeypot="bot-field" class="space-y-5">
          <input type="hidden" name="form-name" value="quote" />
          <p class="hidden"><label>Don’t fill this out if you’re human: <input name="bot-field" /></label></p>
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-[11px] muted uppercase tracking-widest mb-2">Name</label>
              <input name="name" required class="w-full bg-white border line rounded-[3px] px-4 py-3 text-[.95rem] focus:outline-none focus:border-[var(--accent)]" />
            </div>
            <div>
              <label class="block text-[11px] muted uppercase tracking-widest mb-2">Phone</label>
              <input name="phone" type="tel" class="w-full bg-white border line rounded-[3px] px-4 py-3 text-[.95rem] focus:outline-none focus:border-[var(--accent)]" />
            </div>
          </div>
          <div>
            <label class="block text-[11px] muted uppercase tracking-widest mb-2">Email</label>
            <input name="email" type="email" required class="w-full bg-white border line rounded-[3px] px-4 py-3 text-[.95rem] focus:outline-none focus:border-[var(--accent)]" />
          </div>
          <div>
            <label class="block text-[11px] muted uppercase tracking-widest mb-2">What do you need built?</label>
            <select name="service" class="w-full bg-white border line rounded-[3px] px-4 py-3 text-[.95rem] focus:outline-none focus:border-[var(--accent)]">
              <option>Custom steel fabrication</option>
              <option>Aluminium fabrication</option>
              <option>Stainless steel fabrication</option>
              <option>Welding / repair</option>
              <option>Something else</option>
            </select>
          </div>
          <div>
            <label class="block text-[11px] muted uppercase tracking-widest mb-2">Details</label>
            <textarea name="message" rows="5" placeholder="Tell us about the job — sizes, materials, quantities, deadline…" class="w-full bg-white border line rounded-[3px] px-4 py-3 text-[.95rem] focus:outline-none focus:border-[var(--accent)]"></textarea>
          </div>
          <button type="submit" class="btn btn-primary w-full !py-4 text-base">Send Enquiry</button>
          <p class="text-xs muted text-center">Prefer to talk? Call <a href={phoneTel} class="accent font-semibold">{home.business.phone}</a> — Mon–Fri, 7:30am–4pm.</p>
        </form>
      </div>
    </div>
  </div>
</section>

<!-- CTA BANNER -->
<section class="relative">
  <img src={home.ctaBanner.image} alt="Fabrication in progress" class="absolute inset-0 imgcover" />
  <div class="absolute inset-0" style="background:rgba(15,16,20,.78)"></div>
  <div class="relative z-10 max-w-[1280px] mx-auto px-6 py-20 lg:py-24 flex flex-col md:flex-row items-center justify-between gap-8 text-white text-center md:text-left">
    <h2 class="h-feat font-display max-w-2xl">{home.ctaBanner.heading}</h2>
    <div class="flex flex-wrap gap-3 justify-center">
      <a href="#contact" class="btn btn-light">{home.ctaBanner.ctaPrimary}</a>
      <a href={phoneTel} class="btn btn-outline-light">{home.ctaBanner.ctaSecondary}</a>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer class="bg-ink text-white">
  <div class="max-w-[1280px] mx-auto px-6 py-16 grid md:grid-cols-3 gap-10">
    <div>
      <div class="mb-5">
        <img src="/assets/logo/offer-logo-full.png" alt="Offer Fabrications" class="h-20 w-auto" />
      </div>
      <p class="text-white/55 text-sm max-w-xs leading-relaxed">{home.footer.blurb}</p>
    </div>
    <div>
      <h4 class="text-[11px] uppercase tracking-widest text-white/40 mb-4 font-semibold">Explore</h4>
      <ul class="space-y-2.5 text-white/70 text-sm">
        <li><a href="#services" class="hover:text-white transition">Capabilities</a></li>
        <li><a href="#work" class="hover:text-white transition">Our Work</a></li>
        <li><a href="#industries" class="hover:text-white transition">Industries</a></li>
        <li><a href="#about" class="hover:text-white transition">About</a></li>
        <li><a href="#contact" class="hover:text-white transition">Get a Quote</a></li>
      </ul>
    </div>
    <div>
      <h4 class="text-[11px] uppercase tracking-widest text-white/40 mb-4 font-semibold">Contact</h4>
      <ul class="space-y-2.5 text-white/70 text-sm">
        <li><a href={phoneTel} class="hover:text-white transition">{home.business.phone}</a></li>
        <li><a href={mailTo} class="hover:text-white transition">{home.business.email}</a></li>
        <li>{home.business.address}</li>
        <li><a href={home.business.instagramUrl} target="_blank" rel="noopener" class="hover:text-white transition">{home.business.instagram}</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-white/10">
    <div class="max-w-[1280px] mx-auto px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-white/45">
      <span>© <span id="yr"></span> Offer Fabrications. All rights reserved.</span>
      <span>Website by <a href="https://intrlude.com.au" target="_blank" rel="noopener" class="text-white/70 hover:text-[var(--accent)] transition">Intrlude</a></span>
    </div>
  </div>
</footer>

<!-- STICKY MOBILE BAR -->
<div id="mobileBar" class="fixed bottom-0 inset-x-0 z-30 bg-white border-t line grid grid-cols-2 gap-2 p-2.5 lg:hidden">
  <a href={phoneTel} class="btn btn-ghost !py-3 text-sm">Call</a>
  <a href="#contact" class="btn btn-primary !py-3 text-sm">Get a Quote</a>
</div>

<script is:inline>
  document.getElementById('yr').textContent = new Date().getFullYear();
  const menu = document.getElementById('mobileMenu');
  const openM = () => { menu.classList.remove('hidden-menu'); document.body.style.overflow='hidden'; };
  const closeM = () => { menu.classList.add('hidden-menu'); document.body.style.overflow=''; };
  document.getElementById('menuBtn').addEventListener('click', openM);
  document.getElementById('menuClose').addEventListener('click', closeM);
  menu.querySelectorAll('.menu-item').forEach(a => a.addEventListener('click', closeM));
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
  }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));
</script>
</body>
</html>
