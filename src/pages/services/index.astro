---
import Location from "../../layouts/Location.astro";
import services from "../../../content/services.json";
import homeData from "../../../content/home.json";
const home = homeData;
const SITE = "https://offerfabrications.com.au";
const canonical = SITE + "/services/";
const phoneTel = "tel:" + home.business.phoneHref;

const title = "Metal Fabrication Services Perth | Steel, Stainless, Aluminium & Welding — Offer Fabrications";
const description = "Metal fabrication services in Perth WA: custom and structural steel, stainless steel, aluminium fabrication, MIG & TIG welding, CNC cutting & folding and production manufacturing. Aboriginal-owned, Supply Nation certified.";

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": SITE + "/#business",
      "name": "Offer Fabrications",
      "url": SITE + "/",
      "telephone": home.business.phone,
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Metal fabrication services",
        "itemListElement": services.map((s) => ({
          "@type": "Offer",
          "itemOffered": { "@type": "Service", "name": s.name, "url": `${SITE}/services/${s.slug}/` }
        }))
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE + "/" },
        { "@type": "ListItem", "position": 2, "name": "Services", "item": canonical }
      ]
    }
  ]
};
---
<Location title={title} description={description} canonical={canonical} schema={schema}>
  <section class="bg-ink text-white">
    <div class="max-w-[1100px] mx-auto px-6 pt-16 pb-14 lg:pt-24 lg:pb-20">
      <nav class="text-[12px] text-white/45 mb-6 flex items-center gap-2">
        <a href="/" class="hover:text-white transition">Home</a><span>/</span>
        <span class="text-white/70">Services</span>
      </nav>
      <div class="kicker on-dark mb-5">What we build</div>
      <h1 class="h-hero font-display">Metal fabrication services in Perth</h1>
      <p class="lead !text-white/80 mt-6 max-w-2xl">From custom and structural steel to stainless, aluminium, MIG & TIG welding, CNC folding and production runs — all designed, cut, welded and finished in our Bibra Lake workshop and delivered across Western Australia.</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/#contact" class="btn btn-light">Request a Quote</a>
        <a href={phoneTel} class="btn btn-outline-light">Call {home.business.phone}</a>
      </div>
    </div>
  </section>

  <section class="max-w-[1100px] mx-auto px-6 py-16 lg:py-20">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {services.map((s) => (
        <a href={`/services/${s.slug}/`} class="card p-7 group flex flex-col">
          <h2 class="font-display font-bold text-xl mb-2 group-hover:accent transition">{s.name}</h2>
          <p class="muted text-[.93rem] leading-relaxed flex-1">{s.metaDescription}</p>
          <span class="accent font-display font-semibold text-sm mt-4 inline-flex items-center gap-1.5">Learn more →</span>
        </a>
      ))}
    </div>
  </section>
</Location>
