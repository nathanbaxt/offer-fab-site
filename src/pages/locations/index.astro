---
import Location from "../../layouts/Location.astro";
import locations from "../../../content/locations.json";
import homeData from "../../../content/home.json";
const home = homeData;
const SITE = "https://offerfabrications.com.au";
const canonical = SITE + "/locations/";
const phoneTel = "tel:" + home.business.phoneHref;

const title = "Areas We Serve | Metal Fabrication Across Perth & WA — Offer Fabrications";
const description = "Offer Fabrications delivers custom steel, stainless and aluminium fabrication from our Bibra Lake workshop to Perth and across Western Australia — including Henderson, Kwinana, Cockburn, Rockingham, Fremantle and the northern and eastern industrial hubs.";

const sorted = [...locations].sort((a, b) => a.name.localeCompare(b.name));

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": SITE + "/#business",
      "name": "Offer Fabrications",
      "url": SITE + "/",
      "telephone": home.business.phone,
      "areaServed": sorted.map((l) => ({ "@type": "City", "name": `${l.name}, WA` }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE + "/" },
        { "@type": "ListItem", "position": 2, "name": "Areas We Serve", "item": canonical }
      ]
    }
  ]
};
---
<Location title={title} description={description} canonical={canonical} schema={schema}>
  <section class="bg-ink text-white">
    <div class="max-w-[1100px] mx-auto px-6 pt-16 pb-14 lg:pt-24 lg:pb-20">
      <nav class="text-[12px] text-white/45 mb-6 flex items-center gap-2">
        <a href="/" class="hover:text-white transition">Home</a><span>/</span>
        <span class="text-white/70">Areas We Serve</span>
      </nav>
      <div class="kicker on-dark mb-5">Perth & Western Australia</div>
      <h1 class="h-hero font-display">Metal fabrication across Perth & WA</h1>
      <p class="lead !text-white/80 mt-6 max-w-2xl">From our Bibra Lake workshop we fabricate custom steel, stainless steel and aluminium for businesses right across Perth's industrial suburbs and deliver, or arrange transport, throughout Western Australia — including the Pilbara and Goldfields mining regions.</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/#contact" class="btn btn-light">Request a Quote</a>
        <a href={phoneTel} class="btn btn-outline-light">Call {home.business.phone}</a>
      </div>
    </div>
  </section>

  <section class="max-w-[1100px] mx-auto px-6 py-16 lg:py-20">
    <div class="mb-10">
      <div class="kicker mb-4">Suburbs & regions</div>
      <h2 class="h-sec font-display">Fabrication delivered across Perth</h2>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {sorted.map((l) => (
        <a href={`/locations/${l.slug}/`} class="card p-5 group flex items-center justify-between">
          <div>
            <div class="font-display font-bold text-[1.05rem] group-hover:accent transition">{l.name}</div>
            <div class="muted text-[.85rem] mt-0.5">{l.region}</div>
          </div>
          <span class="accent text-lg">→</span>
        </a>
      ))}
    </div>
    <p class="muted text-[.95rem] mt-10 max-w-2xl leading-relaxed">Don't see your suburb? We deliver across all of Perth and Western Australia. <a href="/#contact" class="accent font-semibold">Get in touch</a> and we'll sort out delivery or transport for your job.</p>
  </section>
</Location>
