---
import Location from "../../layouts/Location.astro";
import locations from "../../../content/locations.json";
import homeData from "../../../content/home.json";
const home = homeData;
const SITE = "https://offerfabrications.com.au";

export async function getStaticPaths() {
  const locs = (await import("../../../content/locations.json")).default;
  return locs.map((loc) => ({ params: { slug: loc.slug }, props: { loc } }));
}

const { loc } = Astro.props;
const canonical = `${SITE}/locations/${loc.slug}/`;
const phoneTel = "tel:" + home.business.phoneHref;

const capIcons = [
  '<path d="M4 5h16M4 19h16M12 5v14"/><path d="M8 5v2M16 5v2M8 17v2M16 17v2"/>',
  '<path d="M12 3l1.8 5.4L19 10l-5.2 1.6L12 17l-1.8-5.4L5 10l5.2-1.6z"/><path d="M18.5 15.5l.7 2 2 .7-2 .7-.7 2-.7-2-2-.7 2-.7z"/>',
  '<path d="M12 3l9 5-9 5-9-5 9-5z"/><path d="M3 13l9 5 9-5"/>',
  '<rect x="3" y="4" width="18" height="16" rx="1"/><path d="M3 10h18M9 4v16"/>',
  '<circle cx="12" cy="12" r="2.3"/><path d="M12 3v3.5M12 17.5V21M3 12h3.5M17.5 12H21M5.6 5.6l2.5 2.5M15.9 15.9l2.5 2.5M18.4 5.6l-2.5 2.5M8.1 15.9l-2.5 2.5"/>',
  '<path d="M3 7h18M3 18h18M6 7v11M10 7v11M14 7v11M18 7v11"/>',
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": `Metal fabrication in ${loc.name}`,
      "serviceType": "Metal fabrication",
      "description": loc.metaDescription,
      "areaServed": { "@type": "City", "name": `${loc.name}, Western Australia` },
      "provider": {
        "@type": "LocalBusiness",
        "@id": SITE + "/#business",
        "name": "Offer Fabrications",
        "telephone": home.business.phone,
        "email": home.business.email,
        "url": SITE + "/",
        "image": SITE + "/assets/img/hero-ute-generator.jpg",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Unit 14/16 Salpietro Street",
          "addressLocality": "Bibra Lake",
          "addressRegion": "WA",
          "postalCode": "6163",
          "addressCountry": "AU"
        }
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": `Fabrication services for ${loc.name}`,
        "itemListElement": home.capabilities.items.map((c) => ({
          "@type": "Offer",
          "itemOffered": { "@type": "Service", "name": `${c.title} — ${loc.name}` }
        }))
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE + "/" },
        { "@type": "ListItem", "position": 2, "name": "Areas We Serve", "item": SITE + "/locations/" },
        { "@type": "ListItem", "position": 3, "name": loc.name, "item": canonical }
      ]
    }
  ]
};

const nearby = (loc.nearby || [])
  .map((n) => locations.find((l) => l.name === n))
  .filter(Boolean);
---
<Location title={loc.metaTitle} description={loc.metaDescription} canonical={canonical} schema={schema}>
  <!-- HERO -->
  <section class="bg-ink text-white">
    <div class="max-w-[1000px] mx-auto px-6 pt-16 pb-14 lg:pt-24 lg:pb-20">
      <nav class="text-[12px] text-white/45 mb-6 flex items-center gap-2 flex-wrap">
        <a href="/" class="hover:text-white transition">Home</a><span>/</span>
        <a href="/locations/" class="hover:text-white transition">Areas We Serve</a><span>/</span>
        <span class="text-white/70">{loc.name}</span>
      </nav>
      <div class="kicker on-dark mb-5">{loc.region} · {loc.distanceNote}</div>
      <h1 class="h-hero font-display">{loc.h1}</h1>
      <p class="lead !text-white/80 mt-6 max-w-2xl">{loc.intro}</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/#contact" class="btn btn-light">Request a Quote</a>
        <a href={phoneTel} class="btn btn-outline-light">Call {home.business.phone}</a>
      </div>
    </div>
  </section>

  <!-- LOCAL CONTEXT -->
  <section class="max-w-[1000px] mx-auto px-6 py-16 lg:py-20">
    <div class="grid lg:grid-cols-12 gap-8 lg:gap-14 items-start">
      <div class="lg:col-span-7">
        <div class="kicker mb-5">Fabrication for {loc.name}</div>
        <h2 class="h-feat font-display mb-5">Custom metal fabrication, built in Bibra Lake and delivered to {loc.name}.</h2>
        <p class="lead">{loc.localContext}</p>
        <p class="muted mt-4 text-[.98rem] leading-relaxed">We're a workshop-based fabricator — we design, cut, weld and finish in our Bibra Lake workshop, then deliver or arrange transport to {loc.name} and across Western Australia. That focus is how we keep quality and turnaround high on both one-off custom jobs and production runs.</p>
      </div>
      <div class="lg:col-span-5">
        <div class="card p-7">
          <h3 class="font-display font-bold text-lg mb-4">Industries we serve in {loc.name}</h3>
          <ul class="space-y-2.5">
            {(loc.industries || []).map((ind) => (
              <li class="flex items-center gap-3 text-[.98rem]"><span class="accent">▸</span>{ind}</li>
            ))}
          </ul>
          <div class="mt-6 pt-6 border-t line text-[.92rem] muted">
            <div class="font-semibold ink mb-1">Offer Fabrications</div>
            {home.business.address}<br/>
            <a href={phoneTel} class="accent font-semibold">{home.business.phone}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="bg-paper-2 border-y line">
    <div class="max-w-[1100px] mx-auto px-6 py-16 lg:py-20">
      <div class="mb-10">
        <div class="kicker mb-4">What we build</div>
        <h2 class="h-sec font-display">Fabrication services for {loc.name}</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {home.capabilities.items.map((c, i) => (
          <div class="card p-7">
            <svg class="ico mb-5" viewBox="0 0 24 24" set:html={capIcons[i % capIcons.length]}></svg>
            <h3 class="font-display font-bold text-lg mb-2">{c.title}</h3>
            <p class="muted text-[.93rem] leading-relaxed">{c.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- NEARBY + CTA -->
  <section class="max-w-[1100px] mx-auto px-6 py-16 lg:py-20">
    {nearby.length > 0 && (
      <div class="mb-12">
        <div class="kicker mb-4">Nearby areas</div>
        <div class="flex flex-wrap gap-2.5">
          {nearby.map((n) => (
            <a href={`/locations/${n.slug}/`} class="card px-4 py-2.5 text-[.95rem] font-display font-semibold hover:accent">{n.name}</a>
          ))}
          <a href="/locations/" class="card px-4 py-2.5 text-[.95rem] font-display font-semibold hover:accent">All areas →</a>
        </div>
      </div>
    )}
    <div class="bg-ink text-white rounded-[4px] p-9 lg:p-12 flex flex-col md:flex-row md:items-center justify-between gap-6">
      <div>
        <h2 class="h-feat font-display mb-2">Need fabrication in {loc.name}?</h2>
        <p class="text-white/70 max-w-xl">Send a drawing, sketch or photo and we'll come back with a clear quote — usually within a day or two.</p>
      </div>
      <div class="flex flex-wrap gap-3 shrink-0">
        <a href="/#contact" class="btn btn-light">Request a Quote</a>
        <a href={phoneTel} class="btn btn-outline-light">Call Now</a>
      </div>
    </div>
  </section>
</Location>
